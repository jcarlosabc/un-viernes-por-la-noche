{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('path').join(require('os').homedir(),'.claude','session-start.js'))\"",
            "blocking": false
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('path').join(require('os').homedir(),'.claude','session-end.js'))\"",
            "blocking": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const p=require('path'),o=require('os'),fs=require('fs');const t=JSON.parse(d);const name=t.subagent_type||t.description||'';const f=p.join(o.homedir(),'.claude','memory','active-agent.txt');fs.mkdirSync(p.dirname(f),{recursive:true});fs.writeFileSync(f,name);}catch(e){}})\"",
            "blocking": false
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const f=process.env.CLAUDE_TOOL_INPUT_FILE_PATH||''; const bad=['text-[#','bg-[#','border-[#']; const found=bad.filter(p=>f&&require('fs').existsSync(f)&&require('fs').readFileSync(f,'utf8').includes(p)); if(found.length){console.error('uvpln: color hardcodeado -- usa un token del design system');process.exit(2);}\"",
            "blocking": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"try{require('fs').unlinkSync(require('path').join(require('os').homedir(),'.claude','memory','active-agent.txt'))}catch(e){}\"",
            "blocking": false
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const f=process.env.CLAUDE_TOOL_INPUT_FILE_PATH||''; if(f&&(f.endsWith('.tsx')||f.endsWith('.ts'))){const c=require('fs').existsSync(f)?require('fs').readFileSync(f,'utf8'):''; const n=(c.match(/:\\s*any/g)||[]).length; if(n>0)console.warn('uvpln: '+n+' uso(s) de any en '+f+' -- ojo parcero');}\"",
            "blocking": false
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node -e \"require(require('path').join(require('os').homedir(),'.claude','statusline.cjs'))\"",
    "refreshInterval": 10
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ]
  }
}
